DB_URL=jdbc:postgresql://localhost:5432/ai_life_management
DB_USERNAME=postgres
DB_PASSWORD=postgres
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TYPE=redis
JWT_SECRET=change-this-dev-secret-change-this-dev-secret

# AI provider
AI_PROVIDER=llama

# Groq exposes Llama models through an OpenAI-compatible chat-completions endpoint.
LLAMA_BASE_URL=https://api.groq.com/openai/v1
LLAMA_MODEL=llama-3.3-70b-versatile
LLAMA_API_KEY=
